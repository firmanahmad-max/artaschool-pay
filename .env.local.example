# Salin ke .env.local lalu isi nilainya. Lihat CONTEXT.md §Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only: signed URL, notif worker
WA_GATEWAY_URL=
WA_GATEWAY_TOKEN=
SENTRY_DSN=                       # monitoring server; kosong = Sentry mati total
NEXT_PUBLIC_SENTRY_DSN=           # monitoring browser (ikut terkirim ke klien)
SENTRY_ORG=                       # opsional: unggah source map saat build
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
CRON_SECRET=                      # worker antrean notifikasi (/api/jobs/notifications)
OCR_API_URL=                      # OCR bukti (Sumopod) — kosong = OCR mati, form manual
OCR_API_KEY=
SEND_SMS_HOOK_SECRET=              # auth hook OTP: format "v1,whsec_<base64>" dari Supabase
